---
// ============================================================
// AboutMe.astro — "About Me" / Contact page
// ============================================================
// To edit content: update the fields below the imports.
// No Astro/framework knowledge required — just edit the strings!
// ============================================================

// ✏️ EDIT YOUR PERSONAL INFO HERE
const info = {
  heading:     "Let's Build Together",
  tagline:     "Whether you're looking to automate your workflow, containerize an application, or scale your infrastructure — I'm ready to help. My inbox is always open!",
  location:    "Malaysia",
  phone:       "+6 016 447 9169",
  email:       "yxtan2000@gmail.com",
  linkedin:    "https://www.linkedin.com/in/yan-xue-t-53730a206/",
  resumePdf:   "/Resume_2026.pdf",
};

// ✏️ EDIT YOUR PROFILE SUMMARY BULLETS HERE
const highlights = [
  "3+ years building CI/CD pipelines at Intel Technology Sdn Bhd",
  "Certified Jenkins Engineer (CJE) & Kubernetes Application Developer (CKAD)",
  "Experienced with GitHub Actions, Docker, Kubernetes, Azure & Python automation",
  "Bachelor's in Computer Science (Data Science) — TARUMT, Kuala Lumpur",
  "AI Hackathon Top 5 Finalist — YOLO-based Object Detection",
];
---

<section id="about-me" class="py-24 px-6 relative overflow-hidden">
  <div class="max-w-4xl mx-auto relative z-10">

    <!-- Section Header -->
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">About Me</h2>
      <div class="h-1 w-24 bg-accent rounded-full shadow-[0_0_10px_rgba(139,92,246,0.5)]"></div>
    </div>

    <!-- Profile Card -->
    <div class="glass rounded-3xl p-10 md:p-14 hover:shadow-[0_0_50px_rgba(139,92,246,0.12)] transition-shadow duration-500 mb-10">
      <h3 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white mb-5">{info.heading}</h3>
      <p class="text-lg text-gray-700 dark:text-gray-300 leading-loose mb-8 max-w-2xl">
        {info.tagline}
      </p>

      <!-- Highlights -->
      <ul class="space-y-3 mb-10">
        {highlights.map(h => (
          <li class="flex items-start gap-3 text-gray-700 dark:text-gray-300">
            <span class="mt-1.5 shrink-0 w-2 h-2 rounded-full bg-accent"></span>
            {h}
          </li>
        ))}
      </ul>

      <!-- Contact Info Row -->
      <div class="flex flex-wrap gap-4 text-sm text-gray-500 dark:text-gray-500 mb-10 border-t border-gray-200 dark:border-white/10 pt-6">
        <span>📍 {info.location}</span>
        <span>📞 {info.phone}</span>
        <span>✉️ <a href={`mailto:${info.email}`} class="hover:text-primary transition-colors">{info.email}</a></span>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a
          href={`mailto:${info.email}`}
          class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 shadow-[0_0_15px_rgba(16,185,129,0.4)] hover:shadow-[0_0_30px_rgba(16,185,129,0.7)] transition-all hover:-translate-y-1"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email Me
        </a>

        <a
          href={info.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 glass text-gray-900 dark:text-white font-bold rounded-xl hover:bg-blue-500/10 hover:border-blue-400/40 transition-all border border-gray-300/50 dark:border-white/10 group"
        >
          <svg class="w-5 h-5 group-hover:text-blue-400 transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
          LinkedIn
        </a>

        <a
          href={info.resumePdf}
          download
          class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 glass text-gray-900 dark:text-white font-bold rounded-xl hover:bg-gray-200/50 dark:hover:bg-white/10 transition-all border border-gray-300/50 dark:border-white/10 group"
        >
          <svg class="w-5 h-5 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Download CV
        </a>
      </div>
    </div>

  </div>
</section>
