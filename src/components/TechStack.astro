---
// TechStack.astro
const coreTechs = [
  { name: "GitHub Actions", category: "CI/CD", icon: "M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z M14 2v4a2 2 0 0 0 2 2h4 M10 9H8 M16 13H8 M16 17H8" },
  { name: "Jenkins", category: "CI/CD", icon: "M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
  { name: "Docker", category: "Containerization", icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" },
  { name: "Kubernetes", category: "Orchestration", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
  { name: "Azure", category: "Cloud", icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" },
  { name: "Python", category: "Scripting", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
];

const skills = [
  "Bash", "Java", "Singularity", "PostgreSQL", "MongoDB", "MySQL",
  "GitHub", "Gerrit", "MLOps", "NLP", "Linux", "IaC"
];

const certifications = [
  { name: "Certified Jenkins Engineer (CJE)", issuer: "CloudBees" },
  { name: "Certified Kubernetes Application Developer (CKAD)", issuer: "CNCF" },
  { name: "AI Hackathon Finalist", issuer: "Intel – Vision-based Object Detection (YOLO)" },
];
---
<section id="tech" class="py-24 px-6 relative">
  <div class="max-w-6xl mx-auto">
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">Tech Stack</h2>
      <div class="h-1 w-24 bg-secondary rounded-full shadow-[0_0_10px_rgba(14,165,233,0.5)]"></div>
      <p class="mt-6 text-xl text-gray-600 dark:text-gray-400 max-w-2xl">
        3+ years of hands-on experience with CI/CD, containerization, and cloud infrastructure automation.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 mb-16">
      {coreTechs.map((tech, i) => (
        <div class="tech-card glass p-8 rounded-2xl group hover:-translate-y-2 hover:shadow-[0_10px_30px_rgba(14,165,233,0.15)] transition-all duration-300 opacity-0 translate-y-8 flex flex-col items-center text-center">
          <div class="w-16 h-16 mb-6 rounded-xl bg-gray-100/50 dark:bg-white/5 border border-gray-300/50 dark:border-white/10 flex items-center justify-center text-gray-500 group-hover:text-secondary group-hover:border-secondary/50 group-hover:bg-secondary/10 transition-colors">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={tech.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-xl text-gray-900 dark:text-white capitalize mb-1">{tech.name}</h3>
          <p class="text-sm text-primary uppercase tracking-wider font-semibold">{tech.category}</p>
        </div>
      ))}
    </div>
    
    <!-- Additional Skills -->
    <div class="skills-container opacity-0 mb-16">
      <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">Additional Tools & Languages</h3>
      <div class="flex flex-wrap gap-4">
        {skills.map(skill => (
          <span class="skill-badge px-5 py-2.5 glass text-gray-700 dark:text-gray-300 rounded-full text-sm font-medium hover:text-gray-900 dark:hover:text-white hover:border-primary/50 transition-colors cursor-default">
            {skill}
          </span>
        ))}
      </div>
    </div>

    <!-- Certifications -->
    <div class="skills-container opacity-0">
      <h3 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">Certifications & Achievements</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {certifications.map(cert => (
          <div class="glass rounded-xl p-5 border-l-4 border-primary hover:-translate-y-1 transition-transform duration-300">
            <p class="font-bold text-gray-900 dark:text-white text-sm mb-1">{cert.name}</p>
            <p class="text-xs text-primary font-medium">{cert.issuer}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    // Tech Cards
    gsap.to('.tech-card', {
      scrollTrigger: {
        trigger: '#tech',
        start: "top 75%",
      },
      opacity: 1,
      y: 0,
      duration: 0.6,
      stagger: 0.1,
      ease: "back.out(1.2)"
    });

    // Skills Container
    gsap.to('.skills-container', {
      scrollTrigger: {
        trigger: '.skills-container',
        start: "top 90%",
      },
      opacity: 1,
      duration: 0.8,
      ease: "power2.out"
    });
  });
</script>
