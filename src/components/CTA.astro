---
// CTA.astro
---
<section id="contact" class="py-32 px-6 relative overflow-hidden">
  <div class="max-w-4xl mx-auto relative z-10 glass rounded-3xl p-10 md:p-16 text-center hover:shadow-[0_0_50px_rgba(16,185,129,0.15)] transition-shadow duration-500">
    <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Let's Build Together</h2>
    <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-12 leading-loose">
      Whether you're looking to automate your workflow, containerize an application, or scale your infrastructure, I'm ready to help. My inbox is always open!
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
      <a href="mailto:hello@example.com" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 shadow-[0_0_15px_rgba(16,185,129,0.4)] hover:shadow-[0_0_30px_rgba(16,185,129,0.7)] transition-all hover:-translate-y-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Email Me
      </a>
      
      <a href="/resume.pdf" class="w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-4 glass text-white font-bold rounded-xl hover:bg-white/10 hover:border-white/30 transition-all border border-white/10 group">
        <svg class="w-5 h-5 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download CV
      </a>
    </div>
  </div>
</section>
