---
// Experience.astro
const experiences = [
  {
    role: "Infrastructure & DevOps Engineer",
    company: "Intel Technology Sdn Bhd",
    period: "Nov 2022 – Dec 2025",
    description: "Built and maintained CI/CD pipelines and cloud-native infrastructure for multiple cross-functional client projects. Led repository migrations and drove automation across the entire SDLC.",
    tech: ["GitHub Actions", "Jenkins", "Docker", "Kubernetes", "Python", "Azure"],
    achievements: [
      "Migrated legacy Gerrit repositories to GitHub Enterprise, reducing time-to-production from days to hours",
      "Redesigned CI/CD systems that compressed code-testing feedback loops from hours to minutes",
      "Implemented MLOps automation, reducing AI project build effort from 5 minutes of manual steps to zero",
      "Automated weekly build tasks, reducing manual developer effort from 2 hours/week to minutes",
      "Top 5 finalist in internal AI Hackathon with a YOLO-based Vision Object Detection solution"
    ]
  },
  {
    role: "AI Research Assistant",
    company: "TARUMT, Kuala Lumpur",
    period: "Mar 2021 – Sep 2022",
    description: "Conducted specialized NLP research focused on data extraction and contextual information retrieval from Malaysian Code-Mixed text, transforming raw communication data into structured insights.",
    tech: ["Python", "NLP", "Data Extraction", "Research"],
    achievements: [
      "Applied NLP techniques to transform messy, unstructured code-mixed text into actionable structured data",
      "Focused on contextual information retrieval within the Malaysian multilingual communication domain"
    ]
  }
];
---
<section id="experience" class="py-24 px-6 relative">
  <div class="max-w-4xl mx-auto relative z-10">
    <div class="mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">Work Experience</h2>
      <div class="h-1 w-24 bg-primary rounded-full shadow-[0_0_10px_rgba(16,185,129,0.5)]"></div>
    </div>

    <div class="relative border-l border-gray-300 dark:border-white/20 ml-3 md:ml-0">
      {experiences.map((exp, index) => (
        <div class="exp-card mb-12 ml-10 relative group opacity-0 translate-y-12">
          <span class="absolute -left-[49px] flex items-center justify-center w-6 h-6 bg-white dark:bg-bg-dark rounded-full border-2 border-primary group-hover:border-secondary group-hover:shadow-[0_0_15px_rgba(14,165,233,0.6)] transition-all">
          </span>
          <div class="glass p-8 rounded-2xl group-hover:-translate-y-1 transition-transform duration-300">
            <div class="flex flex-col md:flex-row md:items-center justify-between mb-4">
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">{exp.role}</h3>
              <span class="text-sm font-medium text-secondary mt-2 md:mt-0 px-3 py-1 bg-secondary/10 rounded-full border border-secondary/20 whitespace-nowrap">{exp.period}</span>
            </div>
            <h4 class="font-semibold text-primary mb-4">{exp.company}</h4>
            <p class="text-gray-600 dark:text-gray-300 mb-5 leading-relaxed">
              {exp.description}
            </p>
            <!-- Key Achievements -->
            <ul class="mb-6 space-y-1.5">
              {exp.achievements.map(a => (
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full bg-primary"></span>
                  {a}
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2">
              {exp.tech.map((item) => (
                <span class="px-3 py-1 bg-gray-100/50 dark:bg-white/5 border border-gray-300/50 dark:border-white/10 text-gray-700 dark:text-gray-300 text-xs font-medium rounded-md hover:bg-gray-200/50 dark:hover:bg-white/10 transition-colors">
                  {item}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll('.exp-card');
    
    cards.forEach((card, i) => {
      gsap.to(card, {
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
        },
        opacity: 1,
        y: 0,
        duration: 0.6,
        ease: "power3.out",
        delay: i * 0.1
      });
    });
  });
</script>
