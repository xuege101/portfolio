---
// Hero.astro
---

<section id="about" class="relative w-full h-[calc(100vh-8rem)] flex items-center justify-center">
  <!-- Content -->
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 md:px-12 flex flex-col justify-center items-center h-full">
    <div class="glass p-8 md:p-12 rounded-2xl max-w-2xl transform hover:scale-[1.01] transition-transform duration-500 flex flex-col items-center text-center">

      <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-4">
        Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">Francis</span>
      </h1>

      <h2 class="text-xl md:text-2xl font-semibold text-gray-700 dark:text-gray-300 tracking-wide mb-6">
        DevOps Engineer | CI/CD | Cloud & Container Infrastructure
      </h2>

      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl leading-relaxed mb-8 mx-auto">
        Collaborative DevOps Engineer with 3+ years of experience building CI/CD pipelines and resilient cloud infrastructures. Passionate about automation, system reliability, and bridging the gap between development and operations.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/experience`} class="px-8 py-3 bg-primary text-white hover:bg-primary/90 font-medium rounded-lg transition-all shadow-[0_0_15px_rgba(16,185,129,0.3)] hover:shadow-[0_0_25px_rgba(16,185,129,0.6)]">
          View My Work
        </a>
        <a href={`${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/Resume_2026.pdf`} download class="px-8 py-3 border border-gray-900/20 dark:border-white/20 text-gray-900 dark:text-white hover:bg-gray-900/10 dark:hover:bg-white/10 font-medium rounded-lg transition-colors backdrop-blur-sm inline-flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          Download CV
        </a>
      </div>
    </div>
  </div>
</section>
