---
// Header.astro
const pathname = Astro.url.pathname;

// Active link detection
const isActive = (path: string) => {
  const cleanPathname = pathname.replace(/\/$/, '');
  const cleanPath = path.replace(/\/$/, '');
  
  if (cleanPath === base.replace(/\/$/, '') || cleanPath === '') {
    return cleanPathname === base.replace(/\/$/, '') || cleanPathname === '';
  }
  return cleanPathname === cleanPath;
};

const base = import.meta.env.BASE_URL;

// ✏️ NAV LINKS — add/remove/reorder items here
const navLinks = [
  {
    label: "Home",
    href: base,
    icon: `<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  },
  {
    label: "About Me",
    href: `${base === '/' ? '' : base}/about`,
    icon: `<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>`,
  },
  {
    label: "Experience",
    href: `${base === '/' ? '' : base}/experience`,
    icon: `<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>`,
  },
  {
    label: "Skills",
    href: `${base === '/' ? '' : base}/skills`,
    icon: `<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>`,
  },
  {
    label: "Projects",
    href: `${base === '/' ? '' : base}/projects`,
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
  },
];

const activeClass  = "flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/90 dark:bg-white/90 text-gray-900 shadow-[0_0_25px_rgba(255,255,255,0.4)] transition-all duration-300";
const inactiveClass = "flex items-center gap-2 px-5 py-2.5 rounded-full text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-200/50 dark:hover:bg-white/10 transition-all duration-300";
---

<!-- Top Fade Mask to prevent content clipping -->
<div class="fixed top-0 left-0 right-0 h-40 bg-gradient-to-b from-gray-50 via-gray-50/90 to-transparent dark:from-gray-950 dark:via-gray-950/90 z-40 pointer-events-none"></div>

<header class="fixed top-6 left-0 right-0 z-50 px-6 mx-auto w-full max-w-7xl flex flex-col md:flex-row items-center justify-between text-sm font-medium">

  <!-- Center: Navigation Pill -->
  <nav class="hidden md:flex items-center p-1.5 rounded-full bg-gray-100/60 dark:bg-white/5 border border-gray-300/50 dark:border-white/10 backdrop-blur-xl shadow-lg mx-auto">
    {navLinks.map(link => (
      <a href={link.href} class={isActive(link.href) ? activeClass : inactiveClass}>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={link.icon}></svg>
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Right: Actions -->
  <div class="hidden md:flex items-center gap-3 mr-4">
    <a
      href={`${base === '/' ? '' : base}/Resume_2026.pdf`}
      download
      class="px-5 py-2.5 rounded-full bg-emerald-500/20 text-emerald-700 dark:text-emerald-300 hover:bg-emerald-500/30 transition-all duration-300 inline-flex items-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Download CV
    </a>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle light/dark mode"
      class="p-2.5 rounded-full bg-gray-100/60 dark:bg-white/5 border border-gray-300/50 dark:border-white/10 backdrop-blur-xl text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-all duration-300 flex items-center justify-center"
    >
      <!-- Sun: visible in dark mode, click to go light -->
      <svg id="icon-sun" class="hidden dark:block w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>
      </svg>
      <!-- Moon: visible in light mode, click to go dark -->
      <svg id="icon-moon" class="block dark:hidden w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>

  <!-- Mobile: Compact bar -->
  <div class="md:hidden flex items-center justify-between w-full bg-gray-100/60 dark:bg-white/5 border border-gray-300/50 dark:border-white/10 backdrop-blur-xl p-3 rounded-2xl mx-4 relative z-50">
    <span class="font-bold text-gray-900 dark:text-white tracking-tight ml-2">
      Francis <span class="text-primary">Tan</span>
    </span>
    <button id="mobile-menu-btn" class="p-2 text-gray-900 dark:text-white focus:outline-none">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-4 right-4 mt-4 p-5 bg-white/95 dark:bg-gray-900/95 backdrop-blur-2xl border border-gray-300/50 dark:border-white/10 rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.1)] flex-col gap-2 z-40 origin-top">
    {navLinks.map(link => (
      <a href={link.href} class={isActive(link.href) ? "flex items-center gap-3 px-4 py-3 rounded-xl bg-gray-100 dark:bg-white/10 text-primary font-bold transition-colors" : "flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/5 font-medium transition-colors"}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={link.icon}></svg>
        {link.label}
      </a>
    ))}
    
    <div class="h-px bg-gray-200 dark:bg-white/10 my-3"></div>
    
    <div class="flex justify-between items-center px-4 py-2 mb-2">
      <span class="text-gray-700 dark:text-gray-300 font-medium">Theme</span>
      <!-- Mobile Theme toggle -->
      <button
        id="mobile-theme-toggle"
        aria-label="Toggle light/dark mode"
        class="p-2.5 rounded-full bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors border border-gray-300/50 dark:border-white/10"
      >
        <!-- Sun: visible in dark mode, click to go light -->
        <svg class="hidden dark:block w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>
        </svg>
        <!-- Moon: visible in light mode, click to go dark -->
        <svg class="block dark:hidden w-[18px] h-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <a
      href={`${base === '/' ? '' : base}/Resume_2026.pdf`}
      download
      class="flex justify-center items-center gap-2 py-3.5 rounded-xl bg-primary text-white font-medium hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      Download CV
    </a>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    // ── Theme Toggle ──────────────────────────────────────────
    const toggleTheme = () => {
      const isDark = document.documentElement.classList.contains('dark');
      document.documentElement.classList.toggle('dark', !isDark);
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
    };

    const themeBtn = document.getElementById('theme-toggle');
    if (themeBtn) themeBtn.addEventListener('click', toggleTheme);

    const mobileThemeBtn = document.getElementById('mobile-theme-toggle');
    if (mobileThemeBtn) mobileThemeBtn.addEventListener('click', toggleTheme);

    // ── Mobile Menu Toggle ────────────────────────────────────
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (mobileMenuBtn && mobileMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.contains('hidden');
        if (isHidden) {
          mobileMenu.classList.remove('hidden');
          mobileMenu.classList.add('flex');
          // Add a tiny delay for animation to kick in if needed
          setTimeout(() => {
            mobileMenu.classList.add('opacity-100', 'scale-100');
            mobileMenu.classList.remove('opacity-0', 'scale-95');
          }, 10);
        } else {
          mobileMenu.classList.add('opacity-0', 'scale-95');
          mobileMenu.classList.remove('opacity-100', 'scale-100');
          setTimeout(() => {
            mobileMenu.classList.add('hidden');
            mobileMenu.classList.remove('flex');
          }, 200); // match transition duration
        }
      });
    }
  });
</script>
