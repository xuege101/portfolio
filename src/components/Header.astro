---
// Header.astro
---

<!-- Mobile Top Bar -->
<div class="md:hidden fixed top-0 w-full h-16 bg-bg-dark/80 backdrop-blur-xl border-b border-white/10 z-40 flex items-center justify-between px-4 transition-transform duration-300">
  <a href="#" class="text-xl font-bold text-white tracking-tight">
    Dev<span class="text-secondary">Ops</span>
  </a>
</div>

<!-- Floating Toggle Button -->
<button id="nav-toggle" class="fixed z-[60] top-3 right-4 md:top-6 md:left-6 md:right-auto p-2 bg-gray-900/80 backdrop-blur border border-white/20 rounded-lg text-white hover:text-secondary hover:bg-gray-800 transition-all focus:outline-none">
  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path id="toggle-icon-path" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
  </svg>
</button>

<!-- Sidebar -->
<header id="sidebar" class="fixed top-0 left-0 z-50 w-full md:w-[20%] min-w-[280px] h-screen bg-gray-900/95 backdrop-blur-xl border-r border-white/10 transition-transform duration-300 -translate-x-full md:translate-x-0 flex flex-col">
  <div class="flex flex-col h-full p-8 pt-20 md:pt-28 justify-between">
    
    <div class="hidden md:block mb-8">
      <a href="#" class="text-2xl font-bold text-white tracking-tight">
        Dev<span class="text-secondary">Ops</span>
      </a>
    </div>
    
    <nav class="flex flex-col gap-6 text-sm font-medium text-gray-400 w-full mb-auto relative">
      <a href="#about" class="nav-item group flex items-center gap-3 hover:text-white transition-colors py-2 relative z-10 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-70 group-hover:text-secondary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        About
      </a>
      <a href="#experience" class="nav-item group flex items-center gap-3 hover:text-white transition-colors py-2 relative z-10 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-70 group-hover:text-secondary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Experience
      </a>
      <a href="#tech" class="nav-item group flex items-center gap-3 hover:text-white transition-colors py-2 relative z-10 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-70 group-hover:text-secondary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
        Tech Stack
      </a>
      <a href="#projects" class="nav-item group flex items-center gap-3 hover:text-white transition-colors py-2 relative z-10 w-full">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 opacity-70 group-hover:text-secondary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/></svg>
        Projects
      </a>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('nav-toggle');
    const sidebar = document.getElementById('sidebar');
    const toggleIconPath = document.getElementById('toggle-icon-path');
    const mainContent = document.getElementById('main-content');
    
    // Desktop shows initially, mobile hides initially
    let isOpen = window.innerWidth >= 768;

    const updateState = () => {
      if (isOpen) {
        // Open
        sidebar?.classList.remove('-translate-x-full');
        sidebar?.classList.add('translate-x-0');
        mainContent?.classList.add('md:pl-[20%]', 'md:pl-[280px]'); // Safe fallback with width matching min-w
        toggleIconPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
      } else {
        // Closed
        sidebar?.classList.remove('translate-x-0');
        sidebar?.classList.add('-translate-x-full');
        mainContent?.classList.remove('md:pl-[20%]', 'md:pl-[280px]');
        toggleIconPath?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger
      }
    };

    // Initial state set
    updateState();

    toggleBtn?.addEventListener('click', () => {
      isOpen = !isOpen;
      updateState();
    });

    // Close on mobile menu link click
    const navLinks = document.querySelectorAll('.nav-item');
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 768) {
          isOpen = false;
          updateState();
        }
      });
    });
  });
</script>
