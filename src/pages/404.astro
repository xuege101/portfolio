---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="404 - Page Not Found">
  <section class="min-h-[calc(100vh-8rem)] flex items-center justify-center px-6">
    <div class="glass p-12 md:p-16 rounded-3xl text-center max-w-2xl transform hover:scale-[1.01] transition-transform duration-500">
      
      <h1 class="text-7xl md:text-9xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary mb-6">
        404
      </h1>
      
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4">
        Oops! Pipeline Broken
      </h2>
      
      <p class="text-gray-600 dark:text-gray-400 text-lg mb-10 leading-relaxed">
        The page you're looking for has been moved, deleted, or possibly never existed. Let's get you back to safety before the system crashes.
      </p>

      <a 
        href={base} 
        class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-primary/90 shadow-[0_0_15px_rgba(16,185,129,0.4)] hover:shadow-[0_0_30px_rgba(16,185,129,0.7)] transition-all hover:-translate-y-1"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Return Home
      </a>
      
    </div>
  </section>
</Layout>
