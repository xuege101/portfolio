---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "DevOps Engineer Portfolio - Explore my work, experience, and tech stack." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    
    <!-- Dark Mode Init Script (prevents FOUC) -->
    <script is:inline>
      const setDarkMode = (transition = true) => {
        const theme = (() => {
          if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        })();

        // Block CSS transitions on initial load to prevent FOUC color flash
        if (!transition) {
          document.documentElement.classList.add('no-theme-transition');
        }

        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }

        // Re-enable transitions after next paint
        if (!transition) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              document.documentElement.classList.remove('no-theme-transition');
            });
          });
        }
      };

      // Block transitions on first load, allow them on navigation swaps
      setDarkMode(false);
      document.addEventListener('astro:after-swap', () => setDarkMode(false));
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 transition-colors duration-300 font-sans antialiased min-h-screen flex flex-col relative">
    <!-- Persistent Ambient Canvas Background -->
    <div transition:persist="background" id="graph-container" class="content--canvas fixed inset-0 w-full h-full z-0 opacity-100 dark:opacity-40 pointer-events-none"></div>

    <div class="flex flex-col w-full min-h-screen relative z-10">
      <Header />
      <main id="main-content" class="flex-grow w-full pt-32 overflow-x-hidden transition-all duration-300">
        <slot />
      </main>
    </div>

    <!-- Pipeline Ambient Background Scripts -->
    <script is:inline src="/js/noise.min.js"></script>
    <script is:inline src="/js/util.js"></script>
    <script is:inline src="/js/pipeline.js"></script>
  </body>
</html>
